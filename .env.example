# Choose which provider the backend talks to: "anthropic" or "groq"
LLM_PROVIDER=groq

# Needed if LLM_PROVIDER=anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Needed if LLM_PROVIDER=groq (console.groq.com -> API Keys)
GROQ_API_KEY=your-groq-api-key-here
# GROQ_MODEL=openai/gpt-oss-120b
